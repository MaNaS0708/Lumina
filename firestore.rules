rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserProfile() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isHr() {
      return role() == 'hr';
    }

    function isManager() {
      return role() == 'manager';
    }

    function isEmployee() {
      return role() == 'employee';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /appConfig/{documentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin() || isHr() || isManager();
      allow create: if isAdmin();
      allow update: if isSelf(userId) || isAdmin() || isHr();
      allow delete: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isHr();
    }

    match /cycles/{cycleId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isHr();
    }

    match /goalSheets/{sheetId} {
      allow read: if signedIn();
      allow create: if isEmployee() || isManager() || isHr() || isAdmin();
      allow update: if isEmployee() || isManager() || isHr() || isAdmin();
      allow delete: if isAdmin() || isHr();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin() || isHr();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /seedStatus/{documentId} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
