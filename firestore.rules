rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verifiedEmail() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userPath());
    }

    function userProfile() {
      return get(userPath());
    }

    function role() {
      return hasUserProfile() ? userProfile().data.role : null;
    }

    function organizationId() {
      return hasUserProfile() ? userProfile().data.organizationId : null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return verifiedEmail() && role() == 'admin';
    }

    function isHr() {
      return verifiedEmail() && role() == 'hr';
    }

    function isManager() {
      return verifiedEmail() && role() == 'manager';
    }

    function isEmployee() {
      return verifiedEmail() && role() == 'employee';
    }

    function inOrganization(orgId) {
      return verifiedEmail() && organizationId() == orgId;
    }

    function validSelfUserCreate(userId) {
      return isSelf(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'email',
          'emailVerified',
          'role',
          'status',
          'departmentId',
          'departmentName',
          'managerId',
          'managerName',
          'organizationId',
          'organizationName',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == false
        && request.resource.data.role in ['employee', 'manager', 'hr', 'admin']
        && request.resource.data.status in ['pending', 'active']
        && request.resource.data.organizationId is string
        && request.resource.data.organizationName is string;
    }

    function validOrganizationCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'name',
          'slug',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.slug is string
        && request.resource.data.createdBy == request.auth.uid;
    }

    match /organizations/{orgId} {
      allow read: if signedIn();
      allow create: if validOrganizationCreate();
      allow update, delete: if isAdmin() && inOrganization(orgId);

      match /appConfig/{documentId} {
        allow read: if inOrganization(orgId);
        allow create, update, delete: if isAdmin() && inOrganization(orgId);
      }

      match /cycles/{cycleId} {
        allow read: if inOrganization(orgId);
        allow create, update, delete: if (isAdmin() || isHr()) && inOrganization(orgId);
      }

      match /departments/{departmentId} {
        allow read: if inOrganization(orgId);
        allow create, update, delete: if (isAdmin() || isHr()) && inOrganization(orgId);
      }

      match /seedStatus/{documentId} {
        allow read: if inOrganization(orgId);
        allow create, update: if isAdmin() && inOrganization(orgId);
        allow delete: if false;
      }
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin() || isHr() || isManager();
      allow create: if validSelfUserCreate(userId) || isAdmin();
      allow update: if isSelf(userId) || isAdmin() || isHr();
      allow delete: if isAdmin();
    }

    match /goalSheets/{sheetId} {
      allow read: if verifiedEmail();
      allow create: if isEmployee() || isManager() || isHr() || isAdmin();
      allow update: if isEmployee() || isManager() || isHr() || isAdmin();
      allow delete: if isAdmin() || isHr();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin() || isHr();
      allow create: if verifiedEmail();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
